# --- Required ---

# Discord bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=

# Discord server (guild) ID
DISCORD_GUILD_ID=

# Voice channel the bot listens in
DISCORD_VOICE_CHANNEL_ID=

# OpenAI API key (used for Whisper speech-to-text)
OPENAI_API_KEY=

# ElevenLabs API key and voice ID (text-to-speech)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Tango voice turn bridge
TANGO_VOICE_TURN_URL=http://127.0.0.1:8787/voice/turn

# Bot display name (used in system prompt, transcript logging)
# BOT_NAME=Tango

# --- Optional ---

# Optional Tango voice bridge overrides.
# TANGO_VOICE_COMPLETION_URL=http://127.0.0.1:8787/voice/completion
# TANGO_VOICE_AGENT_ID=main
# TANGO_VOICE_API_KEY=
# TANGO_VOICE_TIMEOUT_MS=45000
# TANGO_VOICE_MAX_RETRIES=2

# Discord text channel for transcript logging (when not using a topic channel)
# LOG_CHANNEL_ID=

# Silence duration in ms before processing speech (defaults to 500)
# Adjustable at runtime with ~delay command
# SILENCE_DURATION_MS=500

# Speech detection threshold — RMS energy below this is treated as noise (defaults to 500)
# Higher = ignores more background noise. Adjustable at runtime with ~noise command
# SPEECH_THRESHOLD=500

# Minimum speech duration in ms to be considered valid speech (defaults to 600)
# MIN_SPEECH_DURATION_MS=600

# Audio processing mode: discord (legacy endpointing) or local (manual stream + Silero VAD)
# AUDIO_PROCESSING=discord

# Endpointing mode:
# - silence: process each VAD segment immediately (default)
# - indicate: gated manual-close flow (start with the wake word, end with a wake-prefixed close command)
# ENDPOINTING_MODE=silence
# INDICATE_CLOSE_WORDS=over and out,over,whiskey foxtrot,whiskey delta,i'm done,i'm finished,go ahead
# INDICATE_TIMEOUT_MS=900000

# Experimental chunked STT partials (Phase 3 foundation).
# Final transcript is still produced by full-utterance STT for correctness.
# STT_STREAMING_ENABLED=false
# STT_STREAMING_CHUNK_MS=900
# STT_STREAMING_MIN_CHUNK_MS=450
# STT_STREAMING_OVERLAP_MS=180
# STT_STREAMING_MAX_CHUNKS=8

# Local VAD tuning (used when AUDIO_PROCESSING=local)
# VAD_POSITIVE_SPEECH_THRESHOLD=0.5
# VAD_NEGATIVE_SPEECH_THRESHOLD=0.35
# VAD_FRAME_SAMPLES=512
# LOCAL_STREAM_IDLE_MS=4000

# Directory for session transcript JSONL files
# SESSIONS_DIR=~/.tango/voice/sessions

# Queue/inbox persistence file
# VOICE_QUEUE_STATE_PATH=~/.tango/voice-queue-state.json

# Local Whisper STT server URL (preferred over OpenAI cloud Whisper)
# WHISPER_URL=http://localhost:8178

# Local TTS backend selection and fallback
# TTS_BACKEND=kokoro
# TTS_FALLBACK_BACKEND=chatterbox
# TTS_PRIMARY_RETRY_MS=30000

# Kokoro TTS (local)
# KOKORO_URL=http://127.0.0.1:8880
# KOKORO_VOICE=af_bella

# Chatterbox TTS (local)
# CHATTERBOX_URL=http://127.0.0.1:4123
# CHATTERBOX_VOICE=default

# Utility channel for quick completions (channel disambiguation, etc.)
# UTILITY_CHANNEL_ID=

# Minimum silence between earcons in ms (default: 500)
# EARCON_MIN_GAP_MS=500

# Dependency monitor (local STT/TTS health checks while voice pipeline is running)
# DEPENDENCY_HEALTHCHECK_MS=15000
# DEPENDENCY_AUTO_RESTART=false
# WHISPER_RESTART_COMMAND=
# KOKORO_RESTART_COMMAND=
# CHATTERBOX_RESTART_COMMAND=
