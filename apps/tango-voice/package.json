{
  "name": "@tango/tango-voice",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc && cp src/channels.json dist/channels.json",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:slice2": "vitest run test/slice2-silence.test.ts",
    "test:slice3": "vitest run test/slice3-whisper.test.ts",
    "test:slice4": "vitest run test/slice4-claude.test.ts",
    "test:slice5": "vitest run test/slice5-elevenlabs.test.ts",
    "test:slice5:live": "RUN_LIVE_ELEVENLABS_TESTS=1 vitest run test/slice5-elevenlabs.test.ts",
    "test:slice6": "vitest run test/slice6-pipeline.test.ts",
    "test:slice6:live": "RUN_LIVE_PIPELINE_TESTS=1 vitest run test/slice6-pipeline.test.ts",
    "test:flows": "vitest run test/interaction-flow-harness.test.ts",
    "test:intents": "vitest run test/intent-robustness-matrix.test.ts",
    "flows:report": "tsx src/testing/flow-report.ts",
    "flows:stress": "tsx src/testing/stress-flow-report.ts",
    "flows:stress:inbox": "tsx src/testing/stress-inbox-report.ts",
    "flows:stress:all": "npm run flows:stress && npm run flows:stress:inbox",
    "e2e:voice-loop": "tsx src/testing/e2e-voice-loop-report.ts",
    "e2e:voice-loop:v2": "tsx src/testing/live-v2-voice-report.ts"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "description": "Tango Voice — Discord voice runtime bridge for Tango conversational AI",
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "@tango/core": "0.1.0",
    "@tango/voice": "0.1.0",
    "@anthropic-ai/sdk": "^0.112.5",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@ricky0123/vad-node": "^0.0.3",
    "@snazzah/davey": "^0.1.12",
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "openai": "^6.48.0",
    "prism-media": "^1.3.5",
    "sodium-native": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
