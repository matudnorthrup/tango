# Discord
DISCORD_TOKEN=
DISCORD_TEST_GUILD_ID=
DISCORD_COMMAND_GUILD_ID=
DISCORD_TEST_CHANNEL_ID=
DISCORD_ENABLE_MESSAGE_CONTENT=false

# Runtime
NODE_ENV=development
LOG_LEVEL=info
DISCORD_LISTEN_ONLY=true

# Access control defaults (used when agent config does not set `access`)
TANGO_ACCESS_MODE=allowlist
TANGO_ALLOWLIST_CHANNEL_IDS=
TANGO_ALLOWLIST_USER_IDS=

# Provider (Phase 1)
CLAUDE_CLI_COMMAND=claude
CLAUDE_MODEL=sonnet
CLAUDE_EFFORT=medium
TANGO_PROVIDER_TIMEOUT_MS=300000
# Optional per-provider overrides:
# CLAUDE_TIMEOUT_MS=300000
# CLAUDE_SECONDARY_CLI_COMMAND=/path/to/claude-secondary
# CLAUDE_SECONDARY_MODEL=
# CLAUDE_SECONDARY_EFFORT=medium
# CLAUDE_SECONDARY_TIMEOUT_MS=300000
CLAUDE_HARNESS_COMMAND=claude
CLAUDE_HARNESS_MODEL=
# CLAUDE_HARNESS_EFFORT=medium
# CLAUDE_HARNESS_TIMEOUT_MS=300000
CODEX_CLI_COMMAND=codex
CODEX_MODEL=gpt-5.4
CODEX_REASONING_EFFORT=medium
# CODEX_TIMEOUT_MS=300000
CODEX_SANDBOX=read-only
CODEX_APPROVAL_POLICY=never
TANGO_PROVIDER_RETRY_LIMIT=1
TANGO_WORKER_DISPATCH_TIMEOUT_MS=900000
TANGO_CAPTURE_PROVIDER_RAW=false
TANGO_MEMORY_COMPACTION_TRIGGER_TURNS=24
TANGO_MEMORY_COMPACTION_RETAIN_RECENT_TURNS=8
TANGO_MEMORY_COMPACTION_SUMMARY_MAX_CHARS=1800
TANGO_VOICE_BRIDGE_ENABLED=false
TANGO_VOICE_BRIDGE_HOST=127.0.0.1
TANGO_VOICE_BRIDGE_PORT=8787
TANGO_VOICE_BRIDGE_PATH=/voice/turn
TANGO_VOICE_BRIDGE_API_KEY=
TANGO_VOICE_DEFAULT_SESSION_ID=voice-main
TANGO_VOICE_DEFAULT_AGENT_ID=watson

# Optional runtime path overrides
# TANGO_HOME=~/.tango
# TANGO_PROFILE=default
# TANGO_BROWSER_PROFILE_DIR=
# TANGO_PRINTER_STATUS_URL=http://printer.local/api/v1/status
# TANGO_PRINTER_API_KEY=

# 1Password service account
OP_SERVICE_ACCOUNT_TOKEN=

# Optional config/storage overrides
# TANGO_CONFIG_DIR=
# TANGO_DB_PATH=
